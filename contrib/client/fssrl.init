#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

PROG=/usr/sbin/fssrl-client

disabled_shapers=""

disable_shaping() {
	local value="$1"

	disabled_shapers="$disabled_shapers --disable-shaping $value"
}

start_instance() {
	local section="$1"
	local enabled interface script downstream_min downstream_max upstream_min upstream_max log_level target subtarget interval
	disabled_shapers=""

	config_get_bool enabled "$section" enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get interface "$section" interface "mesh-vpn"
	config_get script "$section" script "/usr/share/fssrl/apply-rate-limit.sh"
	config_get downstream_min "$section" minimum_downstream "0"
	config_get downstream_max "$section" maximum_downstream "0"
	config_get upstream_min "$section" minimum_upstream "0"
	config_get upstream_max "$section" maximum_upstream "0"
	config_get log_level "$section" log_level "info"
	config_get interval "$section" interval "60"
	config_get target "$section" target ""
	config_get subtarget "$section" subtarget ""
	config_get model_name "$section" model_name "unknown"
	config_list_foreach "$section" disable_shaping disable_shaping

	procd_open_instance "$section"
	procd_set_param command "$PROG" --interface "$interface" \
		--script "$script" \
		--downstream-min "$downstream_min" \
		--downstream-max "$downstream_max" \
		--upstream-min "$upstream_min" \
		--log-syslog \
		--log-level "$log_level" \
		--interval "$interval" \
		--upstream-max "$upstream_max" \
		$disabled_shapers \
		--target "$target" \
		--subtarget "$subtarget"
	procd_set_param respawn 3600 5 5
	procd_close_instance
}

start_service() {
	config_load fssrl
	config_foreach start_instance fssrl
}

service_triggers() {
	procd_add_reload_trigger fssrl
}
